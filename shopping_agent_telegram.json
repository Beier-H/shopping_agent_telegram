    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\nconst photos = item.json.message?.photo || item.json.photo;\nif (!photos || photos.length === 0) {\n  throw new Error('No photo found in Telegram message');\n}\n\nconst fileId = photos[photos.length - 1].file_id;\nconst token = 'YOUR_BOT_TOKEN_HERE';\n\n// Step 1 - Get file path\nconst fileInfo = await this.helpers.httpRequest({\n  method: 'GET',\n  url: `https://api.telegram.org/bot${token}/getFile`,\n  qs: { file_id: fileId }\n});\nconst filePath = fileInfo.result.file_path;\n\n// Step 2 - Download image as binary\nconst fileData = await this.helpers.httpRequest({\n  method: 'GET',\n  url: `https://api.telegram.org/file/bot${token}/${filePath}`,\n  encoding: 'arraybuffer',\n  returnFullResponse: false\n});\n\nconst buffer = Buffer.from(fileData);\n\nreturn [{\n  json: {\n    ...item.json,\n    imagePrompt: item.json.message?.caption || \"Find similar products\"\n  },\n  binary: {\n    data0: await this.helpers.prepareBinaryData(buffer, 'image.jpg', 'image/jpeg')\n  }\n}];"
      },
