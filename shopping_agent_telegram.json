    {
      "parameters": {
        "jsCode": "const item = $input.first();\nlet output = item.json.output;\n\nif (typeof output === 'string') {\n  try { output = JSON.parse(output); } catch(e) {}\n}\n\nconst products = output?.products || [];\nif (products.length === 0) return [item];\n\n// Get chatId directly from Telegram Trigger since AI Agent drops previous fields\nconst chatId = $('chatID').first().json.chatId;\n\nreturn products\n  .filter(p => p.image)\n  .map(p => ({\n    json: {\n      chat_id: chatId,\n      photo: p.image,\n      caption: `<b>${p.title}</b>\\n💰 $${(p.price / 83).toFixed(2)}\\n<i>${p.reason}</i>`,\n      output: item.json.output\n    }\n  }));"
      },
